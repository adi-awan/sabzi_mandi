# ============================================
# SABZI MANDI - Environment Variables
# ============================================
# Copy this file to .dev.vars for local development
# For production, use: wrangler secret put <KEY>

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Easypaisa Merchant Credentials (optional - for payment integration)
# Register at: https://developer.easypaisa.com.pk
EASYPAISA_STORE_ID=YOUR_EASYPAISA_STORE_ID
EASYPAISA_USERNAME=YOUR_MERCHANT_USERNAME
EASYPAISA_PASSWORD=YOUR_MERCHANT_PASSWORD
EASYPAISA_HASH_KEY=YOUR_HMAC_HASH_KEY

# WhatsApp Store Owner Number (international format without +)
WHATSAPP_OWNER_NUMBER=923001234567
